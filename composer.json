{
    "name": "kimealabs/symfony-eudi-wallet-bundle",
    "description": "Symfony bundle for EUDI Wallet integration (eIDAS 2.0) — Relying Party, Issuer, Security Authenticator",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "eudi", "eidas", "wallet", "openid4vp", "openid4vci", "sd-jwt", "verifiable-credentials"],
    "homepage": "https://github.com/Kimealabs/symfony-eudi-wallet-bundle",
    "authors": [
        {
            "name": "kimealabs",
            "email": "kimealabs@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "^7.0",
        "symfony/security-bundle": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/cache": "^7.0",
        "web-token/jwt-framework": "^3.3",
        "spomky-labs/cbor-php": "^3.0",
        "endroid/qr-code": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/phpunit-bridge": "^7.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-symfony": "^1.3",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Kimealabs\\EudiWalletBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kimealabs\\EudiWalletBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true
        }
    },
    "extra": {
        "symfony": {
            "require": "^7.0"
        }
    }
}
